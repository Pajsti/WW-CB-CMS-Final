---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

const settings = await getEntry('settings', 'site-settings');
if (!settings?.data.showCalendar) {
  return Astro.redirect('/');
}

const events = (await getCollection('events')).sort(
  (a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf()
);

const categoryColors = {
  zavod: '#ef4444',
  trenink: '#3b82f6',
  akce: '#8b5cf6',
};

const categoryLabels = {
  zavod: 'Závod',
  trenink: 'Trénink',
  akce: 'Akce',
};

const fmtDate = (d: Date) => d.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'short' });
const fmtTime = (d: Date) => d.toLocaleTimeString('cs-CZ', { hour: '2-digit', minute: '2-digit' });
---

<Layout title="Kalendář — WW-CB">
  <h2 class="section-title">Kalendář událostí</h2>
  
  <!-- Legend -->
  <div style="display:flex;gap:20px;margin-bottom:30px;flex-wrap:wrap;">
    {Object.entries(categoryLabels).map(([key, label]) => (
      <div style="display:flex;align-items:center;gap:8px;">
        <div style={`width:16px;height:16px;border-radius:4px;background:${categoryColors[key]}`}></div>
        <span style="font-size:14px;color:var(--muted)">{label}</span>
      </div>
    ))}
  </div>

  <!-- Upcoming events -->
  <div class="card" style="margin-bottom:30px;">
    <h3 style="margin:0 0 20px;font-size:18px;">Nadcházející události</h3>
    <div style="display:flex;flex-direction:column;gap:12px;">
      {events.filter(e => e.data.startDate >= new Date()).slice(0, 5).map(event => (
        <div class="event-card-inline" style={`border-left:4px solid ${categoryColors[event.data.category]};padding:12px 16px;background:var(--card-bg);border-radius:6px;`}>
          <div style="display:flex;justify-content:space-between;align-items:start;gap:16px;">
            <div style="flex:1;">
              <h4 style="margin:0 0 4px;font-size:16px;font-weight:600;">{event.data.title}</h4>
              <p style="margin:0;font-size:14px;color:var(--muted);">
                📍 {event.data.location} • 
                {fmtDate(event.data.startDate)} • 
                {fmtTime(event.data.startDate)}
                {event.data.endDate && ` - ${fmtTime(event.data.endDate)}`}
              </p>
            </div>
            <div style={`padding:4px 12px;border-radius:4px;background:${categoryColors[event.data.category]}20;color:${categoryColors[event.data.category]};font-size:12px;font-weight:600;white-space:nowrap;`}>
              {categoryLabels[event.data.category]}
            </div>
          </div>
        </div>
      ))}
      {events.filter(e => e.data.startDate >= new Date()).length === 0 && (
        <div class="empty-state">
          <p>📅 Žádné nadcházející události.</p>
          <p style="margin-top:12px;font-size:13px;">Přidejte událost v administraci.</p>
        </div>
      )}
    </div>
  </div>

  <!-- All events list -->
  <div class="card">
    <h3 style="margin:0 0 20px;font-size:18px;">Všechny události</h3>
    <div style="display:flex;flex-direction:column;gap:8px;">
      {events.map(event => (
        <div style={`display:flex;gap:16px;align-items:center;padding:12px;border-radius:6px;border-left:4px solid ${categoryColors[event.data.category]};background:var(--card-bg);`}>
          <div style="flex:0 0 60px;text-align:center;">
            <div style="font-size:24px;font-weight:700;line-height:1;">{event.data.startDate.getDate()}</div>
            <div style="font-size:12px;color:var(--muted);text-transform:uppercase;">
              {event.data.startDate.toLocaleDateString('cs-CZ', { month: 'short' })}
            </div>
          </div>
          <div style="flex:1;">
            <h4 style="margin:0 0 4px;font-size:15px;font-weight:600;">{event.data.title}</h4>
            <p style="margin:0;font-size:13px;color:var(--muted);">
              {event.data.location} • {fmtTime(event.data.startDate)}
              {event.data.endDate && ` - ${fmtTime(event.data.endDate)}`}
            </p>
          </div>
          <div style={`padding:4px 10px;border-radius:4px;background:${categoryColors[event.data.category]}20;color:${categoryColors[event.data.category]};font-size:11px;font-weight:600;`}>
            {categoryLabels[event.data.category]}
          </div>
        </div>
      ))}
      {events.length === 0 && (
        <div class="empty-state">
          <p>📅 Zatím žádné události v kalendáři.</p>
          <p style="margin-top:12px;font-size:13px;">Začněte přidáním první události v administraci.</p>
        </div>
      )}
    </div>
  </div>
</Layout>
